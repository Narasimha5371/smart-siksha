# Groq API Configuration
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

# Vector Database
CHROMA_PERSIST_DIR=./chroma_db
